# =========================================================
# こめもっちLINEスタンプカード 環境変数（SPEC.md 3節参照）
# このファイルを .env.local にコピーして値を設定してください
#   cp .env.example .env.local
# =========================================================

# --- Supabase（Phase 1 で必須） ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service Role Key は RLS をバイパスするサーバー専用キー。絶対に公開しないこと
SUPABASE_SERVICE_ROLE_KEY=

# --- Shopify ---
SHOPIFY_SHOP_DOMAIN=xxx.myshopify.com
# Admin API アクセストークンは Phase 4（クーポン発行）で使用。Phase 1 では不要
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_xxxxx
# Webhook signing secret（Phase 1 で必須。Settings > Notifications の Webhook 画面に表示される）
SHOPIFY_WEBHOOK_SECRET=xxxxx
SHOPIFY_API_VERSION=2025-10

# --- LINE ---
LINE_CHANNEL_ID=xxxxx
LINE_CHANNEL_SECRET=xxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxx
# LIFF スタンプカードページで使用（next.config.ts 経由でクライアントに橋渡しされる）
# 未設定でも開発中は ?dev_line_user_id=xxx でシミュレート可能
LINE_LIFF_ID=xxxxx-xxxxx

# --- App ---
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# ⚠️ デザイン確認用の一時的な設定。true にすると本番でも ?dev_line_user_id=xxx で
# ダミーデータのシミュレートが可能になる。LINE公開前に必ず false に戻すこと
ALLOW_DEV_MODE_IN_PRODUCTION=false

# --- Reward（Phase 4 で使用） ---
# SPEC.md 9.6 で作成した「こめもっち 5個プレゼント」の variant ID
GIFT_PRODUCT_VARIANT_ID=
